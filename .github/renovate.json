{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:semverAllWeekly",
    ":automergePr",
    ":dependencyDashboard",
    ":automergeStableNonMajor",
    ":automergeRequireAllStatusChecks",
    ":configMigration",
    ":enableVulnerabilityAlertsWithLabel(security)",
    ":label(dependencies)",
    ":updateNotScheduled",
    ":maintainLockFilesWeekly",
    ":rebaseStalePrs",
    ":automergeMinor",
    ":combinePatchMinorReleases",
    "security:openssf-scorecard"
  ],
  "enabledManagers": [
    "pep621",
    "github-actions",
    "custom.regex",
    "dockerfile"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "backend/pyproject.toml"
      ],
      "matchStrings": [
        "\\[tool\\.uv\\][\\s\\S]*?required-version = \">=(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "astral-sh/uv",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ],
  "prHourlyLimit": 5,
  "prConcurrentLimit": 5,
  "schedule": [
    "before 9am on Monday"
  ],
  "timezone": "Europe/London",
  "pruneStaleBranches": true,
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "pep621"
      ],
      "rangeStrategy": "pin"
    },
    {
      "matchManagers": [
        "pep621"
      ],
      "matchDepNames": [
        "python"
      ],
      "rangeStrategy": "replace"
    },
    {
      "matchDepNames": [
        "ghcr.io/astral-sh/uv",
        "astral-sh/uv"
      ],
      "groupName": "uv",
      "commitMessageAction": "Update",
      "commitMessageTopic": "uv",
      "commitMessageExtra": "to {{newVersion}}"
    },
    {
      "matchManagers": [
        "pep621"
      ],
      "matchDepNames": [
        "granian"
      ],
      "matchDepTypes": [
        "project.dependencies",
        "dependency-groups"
      ],
      "groupName": "granian",
      "commitMessageAction": "Update",
      "commitMessageTopic": "granian",
      "commitMessageExtra": "to {{newVersion}}"
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "Docker base images",
      "commitMessageAction": "Update",
      "commitMessageTopic": "base image",
      "commitMessageExtra": "{{depName}} to {{newVersion}}",
      "matchDepNames": [
        "!ghcr.io/astral-sh/uv"
      ]
    },
    {
      "matchManagers": [
        "pep621"
      ],
      "matchDepTypes": [
        "project.dependencies"
      ],
      "matchDepNames": [
        "!granian"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "runtime dependencies",
      "minimumReleaseAge": "3 days",
      "commitMessageAction": "Update",
      "commitMessageTopic": "runtime deps",
      "commitMessageExtra": "{{depName}} to {{newVersion}}"
    },
    {
      "matchManagers": [
        "pep621"
      ],
      "matchDepTypes": [
        "build-system.requires"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "build dependencies",
      "commitMessageAction": "Update",
      "commitMessageTopic": "build deps",
      "commitMessageExtra": "{{depName}} to {{newVersion}}"
    },
    {
      "matchManagers": [
        "pep621"
      ],
      "matchDepTypes": [
        "dependency-groups"
      ],
      "matchDepNames": [
        "!granian"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "dev dependencies",
      "commitMessageAction": "Update",
      "commitMessageTopic": "dev deps",
      "commitMessageExtra": "{{depName}} to {{newVersion}}"
    },
    {
      "matchManagers": [
        "pep621"
      ],
      "matchDepTypes": [
        "project.dependencies",
        "build-system.requires",
        "dependency-groups"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "commitMessageAction": "Update",
      "commitMessageTopic": "dependency",
      "commitMessageExtra": "{{depName}} to {{newVersion}}"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "GitHub Actions",
      "commitMessageAction": "Update",
      "commitMessageTopic": "GitHub Actions",
      "commitMessageExtra": "{{depName}} to {{newVersion}}"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "commitMessageAction": "Update",
      "commitMessageTopic": "GitHub Actions",
      "commitMessageExtra": "{{depName}} to {{newVersion}}"
    },
    {
      "matchUpdateTypes": [
        "lockFileMaintenance"
      ],
      "groupName": "lockfile maintenance",
      "commitMessageAction": "Update",
      "commitMessageTopic": "lockfiles"
    }
  ]
}
